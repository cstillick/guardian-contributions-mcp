# Copy to .env and adjust. All vars are prefixed GUARDIAN_.

# Storage — SQLite for local dev; Postgres DSN for the hosted deployment.
# GUARDIAN_DATABASE_URL=sqlite:///./guardian.db
GUARDIAN_DATABASE_URL=postgresql+psycopg://guardian:guardian@db:5432/guardian

# Cycle
GUARDIAN_DEFAULT_CYCLE_YEAR=2026

# Auth — comma-separated API keys. Leave empty to disable auth (local single-user).
GUARDIAN_API_KEYS=

# Scheduler (nightly refresh, local time)
GUARDIAN_REFRESH_CRON_HOUR=1
GUARDIAN_REFRESH_CRON_MINUTE=30

# Filesystem
GUARDIAN_PDF_CACHE_DIR=./data/pdf_cache
GUARDIAN_OUTPUT_DIR=./data/output
